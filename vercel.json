{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": "docusaurus-2",
  "redirects": [
    {
      "source": "/S5/:path(.*)",
      "destination": "/s5/:path",
      "permanent": true
    },
    {
      "source": "/S6/:path(.*)",
      "destination": "/s6/:path",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
